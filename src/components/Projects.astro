---
const projects = [
  {
    name: "homelab",
    status: "RUNNING",
    desc: "Bare-metal Proxmox host running k3s with full GitOps, Istio service mesh, Netbird VPN, Dex SSO, and local LLM inference on AMD iGPU. Where I go deep before going to prod.",
    stack: ["Proxmox", "k3s", "ArgoCD", "Istio", "Terraform", "Ollama", "Coroot"],
  },
  {
    name: "ai-agent-platform",
    status: "RUNNING",
    desc: "Multi-agent orchestration for architect → tech → review pipelines, LLM-powered bots, and n8n automation that replaces manual toil with code.",
    stack: ["n8n", "Claude API", "MCP", "Ollama", "Discord"],
  },
  {
    name: "personal-ai",
    status: "RUNNING",
    desc: "Terminal-native AI assistant backed by local LLM, with SQLite persistent memory and MCP tool integrations. Self-contained, no cloud dependency.",
    stack: ["Python", "Ollama", "SQLite", "MCP"],
  },
  {
    name: "ai-driven-activity-auto-discover",
    status: "IN_PROGRESS",
    desc: "Event-driven activity discovery platform. Kafka-driven architecture, Zitadel auth, Next.js frontend.",
    stack: ["FastAPI", "Kafka", "Next.js", "Zitadel", "PostgreSQL"],
  },
];
---

<section class="py-16" id="projects">
  <div class="container">
    <div class="section-header flex items-center">
      <h2 class="section-title">
        <span class="prompt">$</span> ls ~/side-projects/
      </h2>
      <span class="section-meta">[ACTIVE_PROCESSES: {projects.length}]</span>
    </div>

    <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4">
      {projects.map(p => (
        <div class="bg-bg-low p-6 border-l-2 border-primary flex flex-col gap-3
                    transition-colors duration-100 hover:bg-bg-high">
          <div class="flex justify-between items-start">
            <span class={`font-mono text-[9px] font-bold px-1.5 py-0.5 tracking-[0.05em] ${
              p.status === 'RUNNING'
                ? 'bg-primary text-[#003824]'
                : 'bg-[#d29922] text-[#1a0e00]'
            }`}>
              [{p.status}]
            </span>
            <span class="material-symbols-outlined text-[18px] text-primary">
              {p.status === 'RUNNING' ? 'check_circle' : 'pending'}
            </span>
          </div>
          <h3 class="font-mono text-[15px] font-bold lowercase text-text">{p.name}</h3>
          <p class="text-[12px] text-text-muted leading-relaxed flex-1">{p.desc}</p>
          <div class="flex flex-wrap gap-[5px]">
            {p.stack.map(t => (
              <span class="font-mono text-[10px] text-outline bg-bg-container
                           border border-[var(--border-dim)] px-[7px] py-0.5">
                {t}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
