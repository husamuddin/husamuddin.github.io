---
const categories = [
  {
    label: "Platform & Infra",
    icon: "dns",
    skills: ["Kubernetes", "AWS EKS", "GCP", "Terraform", "Terragrunt", "ArgoCD", "Helm", "Kustomize", "Atlantis", "Istio", "cert-manager", "External Secrets Operator", "Netbird VPN", "KEDA"],
  },
  {
    label: "Observability",
    icon: "monitoring",
    skills: ["Prometheus", "Grafana", "Loki", "Alertmanager", "Coroot", "ClickHouse", "OpenTelemetry"],
  },
  {
    label: "CI/CD & GitOps",
    icon: "sync_alt",
    skills: ["GitHub Actions", "ArgoCD", "Argo Workflows", "AWS Step Functions", "Docker", "multi-arch builds"],
  },
  {
    label: "Backend & Languages",
    icon: "code",
    skills: ["Go", "Python", "TypeScript", "Node.js", "FastAPI", "Microservices", "DDD", "Event Sourcing"],
  },
  {
    label: "Data & Messaging",
    icon: "hub",
    skills: ["Kafka", "Kafka Connect", "RabbitMQ", "PostgreSQL", "MongoDB", "Redis", "Elasticsearch"],
  },
  {
    label: "AI & Automation",
    icon: "auto_awesome",
    skills: ["n8n", "Ollama", "Claude API", "MCP", "Multi-agent pipelines", "LLM workflows"],
  },
];
---

<section class="py-16" id="skills">
  <div class="container">
    <div class="section-header flex items-center">
      <h2 class="section-title">
        <span class="prompt">$</span> ls -la /usr/local/skills/
      </h2>
      <span class="section-meta">[MODULES: {categories.length}]</span>
    </div>

    <div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-[2px]">
      {categories.map(cat => (
        <div class="bg-bg-low p-6 border-l-2 border-border transition-colors duration-100
                    hover:border-l-primary">
          <div class="flex items-center gap-2 mb-[14px]">
            <span class="material-symbols-outlined text-[16px] text-primary">{cat.icon}</span>
            <h3 class="text-[11px] font-bold uppercase tracking-[0.1em] text-text">{cat.label}</h3>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {cat.skills.map(s => (
              <span class="font-mono text-[11px] text-text-muted bg-bg-container
                           border border-[var(--border-dim)] px-2 py-[3px] cursor-default
                           transition-all duration-100 hover:border-primary hover:text-primary">
                {s}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
