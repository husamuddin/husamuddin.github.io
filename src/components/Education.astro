---
const certs = [
  { short: "CKA",   name: "Certified Kubernetes Administrator",          issuer: "CNCF" },
  { short: "CKAD",  name: "Certified Kubernetes Application Developer",  issuer: "CNCF" },
  { short: "DDD",   name: "Software Architecture: Domain-Driven Design", issuer: "Coursera" },
  { short: "KAFKA", name: "Kafka: Microservices",                        issuer: "Confluent" },
];
---

<section class="py-16" id="education">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">
        <span class="prompt">$</span> openssl x509 -in cert.crt -text -noout
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-[2px]">
      <div class="bg-bg-low p-7">
        <div class="font-mono text-[11px] text-secondary lowercase tracking-[0.05em] mb-5">
          // certifications
        </div>
        <div class="flex flex-col gap-4">
          {certs.map(c => (
            <div class="flex items-start gap-3">
              <span class="font-mono text-[10px] font-bold text-primary bg-[var(--primary-dim)]
                           border border-primary/25 px-[7px] py-[3px] shrink-0 min-w-[52px]
                           text-center tracking-[0.05em]">
                {c.short}
              </span>
              <div>
                <div class="text-[13px] font-medium text-text leading-[1.4]">{c.name}</div>
                <div class="font-mono text-[11px] text-outline mt-0.5">{c.issuer}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-bg-low p-7">
        <div class="font-mono text-[11px] text-secondary lowercase tracking-[0.05em] mb-5">
          // education
        </div>
        <div class="flex items-start gap-3 mb-4">
          <span class="material-symbols-outlined text-[20px] text-primary shrink-0 mt-0.5">school</span>
          <div>
            <div class="text-[14px] font-semibold text-text leading-[1.4]">B.Sc. Mechatronics Engineering</div>
            <div class="font-mono text-[12px] text-outline mt-[3px]">October 6 University</div>
          </div>
        </div>
        <div class="text-[12px] text-text-muted leading-relaxed italic
                    border-l-2 border-border pl-3">
          Engineering background shapes how I think about systems — feedback loops, failure modes, tolerance margins.
        </div>
      </div>
    </div>
  </div>
</section>
