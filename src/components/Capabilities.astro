---
const caps = [
  {
    icon: "cloud_done",
    name: "GitOps-Platform",
    desc: "End-to-end GitOps with ArgoCD, Helm, Kustomize, and Terraform. Infrastructure that deploys itself.",
  },
  {
    icon: "security",
    name: "Security-Mesh",
    desc: "Istio service mesh, zero-trust architecture, Dex OIDC SSO, and Bitwarden secrets automation.",
  },
  {
    icon: "speed",
    name: "CI/CD-Pipelines",
    desc: "GitHub Actions, Argo Workflows, AWS Step Functions — automated from commit to production.",
  },
  {
    icon: "analytics",
    name: "Observability",
    desc: "Prometheus, Grafana, Loki, Coroot, OTel. Full-stack telemetry and proactive alerting for engineering teams.",
  },
];
---

<section class="py-16">
  <div class="container">
    <div class="section-header flex items-center">
      <h2 class="section-title">
        <span class="prompt">$</span> system-info --capabilities
      </h2>
      <span class="section-meta">[TOTAL_MODULES: 04]</span>
    </div>

    <div class="grid grid-cols-[repeat(auto-fill,minmax(240px,1fr))] gap-4">
      {caps.map(c => (
        <div class="bg-bg-low p-6 border-l-2 border-primary transition-colors duration-100 hover:bg-bg-high">
          <div class="flex justify-between items-start mb-4">
            <span class="font-mono text-[9px] font-bold bg-primary text-[#003824] px-1.5 py-0.5 tracking-[0.05em]">
              [RUNNING]
            </span>
            <span class="material-symbols-outlined text-[22px] text-primary">{c.icon}</span>
          </div>
          <h3 class="text-[16px] font-bold uppercase tracking-[-0.02em] mb-2">{c.name}</h3>
          <p class="text-[12px] text-text-muted leading-relaxed">{c.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
