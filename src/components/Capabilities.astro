---
const caps = [
  {
    icon: "cloud_done",
    name: "GitOps-Platform",
    desc: "End-to-end GitOps with ArgoCD, Helm, Kustomize, and Terraform. Infrastructure that deploys itself.",
  },
  {
    icon: "security",
    name: "Security-Mesh",
    desc: "Istio service mesh, zero-trust architecture, Dex OIDC SSO, and Bitwarden secrets automation.",
  },
  {
    icon: "speed",
    name: "CI/CD-Pipelines",
    desc: "GitHub Actions, Argo Workflows, AWS Step Functions — automated from commit to production.",
  },
  {
    icon: "analytics",
    name: "Observability",
    desc: "Prometheus, Grafana, Loki, Coroot, OTel. Full-stack telemetry and proactive alerting for engineering teams.",
  },
];
---

<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">
        <span class="prompt">$</span> system-info --capabilities
      </h2>
      <span class="section-meta">[TOTAL_MODULES: 04]</span>
    </div>

    <div class="caps-grid">
      {caps.map(c => (
        <div class="cap-card">
          <div class="cap-top">
            <span class="badge">[RUNNING]</span>
            <span class="material-symbols-outlined cap-icon">{c.icon}</span>
          </div>
          <h3 class="cap-name">{c.name}</h3>
          <p class="cap-desc">{c.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section {
    padding: 64px 0;
  }

  .caps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }

  .cap-card {
    background: var(--bg-low);
    padding: 24px;
    border-left: 2px solid var(--primary);
    transition: background 0.1s;
  }

  .cap-card:hover {
    background: var(--bg-high);
  }

  .cap-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .badge {
    font-size: 9px;
    font-weight: 700;
    background: var(--primary);
    color: #003824;
    padding: 2px 6px;
    font-family: monospace;
    letter-spacing: 0.05em;
  }

  .cap-icon {
    color: var(--primary);
    font-size: 22px;
  }

  .cap-name {
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .cap-desc {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  @media (max-width: 600px) {
    .caps-grid { grid-template-columns: 1fr; }
  }
</style>
