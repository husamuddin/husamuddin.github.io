---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Husamuddin Hamad — Cloud Platform Engineer",
  description = "Cloud Platform Engineer with 12+ years building scalable infrastructure, GitOps pipelines, service meshes, and AI automation systems.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Scanline CRT overlay -->
    <div class="scanline-overlay" style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:50;pointer-events:none;opacity:0.2;"></div>

    <!-- Abstract background decoration -->
    <div class="bg-decoration" aria-hidden="true">
      <div class="deco-square deco-square-1"></div>
      <div class="deco-square deco-square-2"></div>
      <div class="deco-line deco-line-h"></div>
      <div class="deco-line deco-line-v"></div>
    </div>

    <slot />
  </body>
</html>

<style>
  .bg-decoration {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    opacity: 0.05;
    pointer-events: none;
  }

  .deco-square {
    position: absolute;
    border: 1px solid var(--primary);
  }

  .deco-square-1 {
    top: 25%;
    left: 25%;
    width: 384px;
    height: 384px;
    transform: rotate(45deg);
  }

  .deco-square-2 {
    bottom: 25%;
    right: 25%;
    width: 384px;
    height: 384px;
    border-color: var(--secondary);
    transform: rotate(-12deg);
  }

  .deco-line {
    position: absolute;
    background: rgba(60, 74, 66, 0.2);
  }

  .deco-line-h {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120%;
    height: 1px;
  }

  .deco-line-v {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    height: 120%;
    width: 1px;
  }
</style>
